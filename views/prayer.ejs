<%- include("partials/header") %>

<form method="post" action="/prayer">
<section class="hero text-center text-white d-flex justify-content-center">
  <div class="container">
    <h1 class="display-4 fw-bold mb-3">Daily Prayer</h1>
    <p class="lead mb-4 px-3 border">
      <%= prayerContent %>
    </p>

    <% post.forEach(function(post, index){ %>
      <div class="border mb-3">
        <div class="box" id="heading">
          <h2><%= post.postday %></h2>
        </div>

        <div class="container">
          <h3 class="fw-bold mb-2"><%= post.postitle %></h3>
          <p class="mb-2"><%= post.postcontent %></p>

          <!-- Amen span with green border -->
          <span class="amen-btn" data-post="<%= index %>" data-title="<%= post.postitle %>">
            🙏 Amen
          </span>
        </div>
      </div>
    <% }); %>
  </div>
</section>
</form>

<!-- Dynamic Popup -->
<div id="amen-popup" class="popup-overlay">
  <div class="popup-content">
    <h3 id="popup-title">Amen!</h3>
    <p id="popup-msg">You said Amen 🙏</p>
    <span id="close-popup">&times;</span>
  </div>
</div>

<%- include("partials/footer") %>